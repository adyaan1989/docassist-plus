# ============================================================
#  DocAssist+ & VoiceBot — Environment Configuration
#  Copy this file:  cp .env.example .env
#  Then fill in your real values below.
# ============================================================


# ── App ──────────────────────────────────────────────────────
# development | staging | production
ENVIRONMENT=development

# Random secret used for signing tokens (change in production!)
SECRET_KEY=change-me-to-a-long-random-string-in-production

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]


# ── OpenAI ───────────────────────────────────────────────────
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# LLM used for answer generation and low-confidence detection fallback
# Options: gpt-4o-mini (cheap) | gpt-4o (smarter) | gpt-3.5-turbo (fastest)
LLM_MODEL=gpt-4o-mini

# Controls creativity (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.3

# Max tokens in each LLM response
LLM_MAX_TOKENS=1024

# Embedding model for document chunks and query vectors
# Options: text-embedding-3-small (cheap) | text-embedding-3-large (better)
EMBEDDING_MODEL=text-embedding-3-small

# Must match the model above (small=1536, large=3072)
EMBEDDING_DIMENSION=1536


# ── Vector Store ─────────────────────────────────────────────
# Which vector DB to use: chroma | pinecone | qdrant
VECTOR_STORE_TYPE=chroma

# ChromaDB: local folder where vectors are saved
CHROMA_PERSIST_DIR=./chroma_db

# Pinecone (only needed if VECTOR_STORE_TYPE=pinecone)
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=docassist


# ── Document Chunking ────────────────────────────────────────
# Number of characters per chunk (512 works well for most docs)
CHUNK_SIZE=512

# Characters shared between consecutive chunks (prevents answer split)
CHUNK_OVERLAP=64

# How many chunks to retrieve per query (more = better recall, higher cost)
TOP_K=5


# ── Session / Redis ──────────────────────────────────────────
# Redis connection string
# Local:      redis://localhost:6379
# Docker:     redis://redis:6379
# Redis Cloud: redis://:password@host:port
REDIS_URL=redis://localhost:6379

# How long a session stays alive without activity (seconds)
# 3600 = 1 hour
SESSION_TTL_SECONDS=3600


# ── Caching ──────────────────────────────────────────────────
# Cache identical query responses to save LLM cost
CACHE_ENABLED=true

# How long to cache a query response (seconds)
# 300 = 5 minutes
CACHE_TTL_SECONDS=300


# ── Rate Limiting ────────────────────────────────────────────
# Max requests per user per time window
RATE_LIMIT_REQUESTS=60

# Time window in seconds
RATE_LIMIT_WINDOW=60


# ── File Upload ──────────────────────────────────────────────
# Maximum allowed upload size in megabytes
MAX_FILE_SIZE_MB=50

# Supported file extensions (do not change unless you add a new parser)
ALLOWED_EXTENSIONS=[".pdf",".txt",".docx",".md",".csv"]

# Folder where raw uploaded files are temporarily stored
UPLOAD_DIR=./uploads


# ── Intent / Emotion Thresholds ──────────────────────────────
# If rule-based confidence is below this → fall back to LLM classifier
# Lower = more LLM calls (more accurate but costs more)
INTENT_CONFIDENCE_THRESHOLD=0.6
EMOTION_CONFIDENCE_THRESHOLD=0.5